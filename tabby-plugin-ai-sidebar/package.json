{
  "name": "tabby-plugin-ai-sidebar",
  "version": "0.1.0",
  "description": "Side-panel tab list with AI tool status, for managing many Claude Code / Codex / opencode sessions in one Tabby window.",
  "keywords": [
    "tabby-plugin"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "webpack --progress --color",
    "watch": "webpack --progress --color --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "files": [
    "dist"
  ],
  "author": "ai-terminal",
  "license": "MIT",
  "devDependencies": {
    "@angular/animations": "^15.2.6",
    "@angular/common": "^15.2.6",
    "@angular/core": "^15.2.6",
    "@angular/forms": "^15.2.6",
    "@angular/platform-browser": "^15.2.6",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/node": "^20.0.0",
    "chrome-remote-interface": "^0.34.0",
    "rxjs": "^7.8.0",
    "tabby-core": "^1.0.231-nightly.0",
    "tabby-local": "^1.0.231-nightly.0",
    "tabby-terminal": "^1.0.231-nightly.0",
    "ts-loader": "^9.5.0",
    "typescript": "~4.9.5",
    "vitest": "^1.6.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.0.0"
  }
}
